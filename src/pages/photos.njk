---
layout: page.njk
title: Photos
permalink: /photos/
pageClass: c-page--photos
---

<a href="/" class="c-photos__back">Back</a>

{% set photos = collections.photos | reverse %}
{% if photos.length > 0 %}
<div class="c-photos__grid">
    {% for photo in photos %}
    <a href="{{ photo.url }}" class="c-photos__grid-item">
        <picture>
            <source srcset="/images/photos/{{ photo.data.image | replace('.jpeg', '.avif') }}" type="image/avif">
            <img class="c-photos__grid-image" src="/images/photos/{{ photo.data.image }}" alt="{{ photo.data.title }}" loading="lazy" decoding="async">
        </picture>
    </a>
    {% endfor %}
</div>
{% endif %}
