<section class="c-widget">
    <h2 class="c-widget__header">
        Code
        <a href="https://github.com/{{ site.social.github }}" target="_blank" class="c-widget__more">GitHub</a>
    </h2>
    {% if github.weeks.length > 0 %}
    <div class="c-github__graph">
        {% for week in github.weeks %}
        <div class="c-github__week">
            {% for day in week.days %}
            <div class="c-github__day c-github__day--level-{{ day.level }}" data-count="{{ day.count }}" data-date="{{ day.date | dateDisplay }}"></div>
            {% endfor %}
        </div>
        {% endfor %}
    </div>
    <p class="c-github__total">{{ github.total }} contributions in the last year</p>
    {% else %}
    <p class="c-widget__empty">Contribution data unavailable.</p>
    {% endif %}
</section>

<script>
(function() {
    var graph = document.querySelector('.c-github__graph');
    var total = document.querySelector('.c-github__total');
    if (!graph || !total) return;
    var defaultText = total.textContent;
    graph.addEventListener('mouseover', function(e) {
        var day = e.target.closest('.c-github__day');
        if (!day) return;
        var count = day.getAttribute('data-count');
        var date = day.getAttribute('data-date');
        total.textContent = count + ' contribution' + (count !== '1' ? 's' : '') + ' on ' + date;
    });
    graph.addEventListener('mouseleave', function() {
        total.textContent = defaultText;
    });
})();
</script>
